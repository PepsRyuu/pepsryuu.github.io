
        /**
         * Scrolls to the specified item. The following properties are required on the passed item:
         *
         * * {Number|String} id - ID for this item.
         * * {Number} children - The amount of children this item has.
         * * {Number|String} parent - The ID of the parent of this item.
         * * {Number} offset - The number of this item relative to its parent.
         *
         * All properties need to be accurate in order to safely scroll to the item. Graphical errors
         * may occur if the information is inaccurate.
         *
         * @method scrollIntoView
         * @param {Object} item
         */
        scrollIntoView: function(item) {
            checkParentExpanded.call(this, item);

            // If the parent is null, to simplify code down below and not have to check for null parent
            // we create a fake object that starts at index 0 and has the root level expansions.
            var parentObj;
            if (item.parent === null) {
                parentObj = {scrollIndex: -1, expansions: _(this).transformedExpansions};
            } else {
                parentObj = find(item.parent, _(this).transformedExpansions);
            }

            // If there's an item above us, we can simply use the scroll end and it's offset to calculate where
            // to scroll to for this item. Considering that transformedExpansions is sorted, the previousItemAbove
            // will be equal to the previous item before this one if it exists.
            var previousItemAbove;

            if (parentObj.expansions) {
                parentObj.expansions.forEach(function(expansion) {
                    if (expansion.offset < item.offset) {
                        previousItemAbove = expansion;
                    }
                });
            }

            var position;
            if (previousItemAbove) {
                position = previousItemAbove.scrollEnd + (item.offset - previousItemAbove.offset);
            } else {
                // If there's no previous item above this one on the same level, we'll just 
                // use the parent offset and add our offset. We add 1 here because we want to
                // add the offset and start from below this item. This is why the root expansions
                // has their offset set to -1.
                position = (parentObj.scrollIndex + 1) + item.offset;
            }

            this.getVirtualScrollBar().setPosition(position);
        }


/*global define, describe, it, expect */
define([
    'dataviz/tree/Tree',
    'jscore/core',
    'test/resources/Utils'
], function (Tree, core, Utils) {
    'use strict';

    describe('Tree', function () {

        var dataStructure = [
            {label: "Item 1", total: 5, children: [
                {label: "Item 1.0", total: 3},
                {label: "Item 1.3", total: 3, children: [
                    {label: "Item 1.3.0", total: 3}
                ]},
                {label: "Item 1.4", total: 3}
            ]},
            {label: "Item 12", total: 20, children: [
                {label: "Item 12.5", total: 2}
            ]}
        ];

        var singleRootNodeStructure = [
            {label: "Item 0", total: 5}
        ];

        var twoRootNodeStructure = [
            {label: "Item 0", total: 5},
            {label: "Item 1", total: 10}
        ];

        var fiveRootNodeStructure = [
            {label: "Item 0", total: 3},
            {label: "Item 1", total: 3},
            {label: "Item 2", total: 3},
            {label: "Item 3", total: 3},
            {label: "Item 4", total: 3}
        ];

        var data = Utils.buildData(100, dataStructure);
        var singleRootNodeData = Utils.buildData(1, singleRootNodeStructure);
        var twoRootNodeData = Utils.buildData(2, twoRootNodeStructure);
        var fiveRootNodeData = Utils.buildData(5, fiveRootNodeStructure);

        function scrollTo(index) {
            tree.getVirtualScrollBar().setPosition(index); // TODO: Fix the offset issue.
            tree.redraw();
        }

        var tree;
        

        describe ("totalRootItems + getData and different scroll positions", function() {

            beforeEach(function() {
                tree = new Tree({
                    getData: Utils.getData.bind(window, data),
                    totalRootItems: 100
                });

                tree.attachTo(core.Element.wrap(bitContainer));
            });

            afterEach(function() {
                tree.destroy();
            })

            it("should show the tree normally", function() {
                Utils.assertItems([
                    "Item 0",
                    "Item 1",
                    "Item 2",
                    "Item 3",
                    "Item 4",
                    "Item 5",
                    "Item 6",
                    "Item 7",
                    "Item 8",
                    "Item 9"
                ]);
            });

            it ("scroll pos 1, nothing expanded", function() {
                scrollTo(1);
                Utils.assertItems([
                    "Item 1",
                    "Item 2",
                    "Item 3",
                    "Item 4",
                    "Item 5",
                    "Item 6",
                    "Item 7",
                    "Item 8",
                    "Item 9",
                    "Item 10"
                ]);
            });

            it ("scroll pos 20, nothing expanded", function() {
                scrollTo(20);
                Utils.assertItems([
                    "Item 20",
                    "Item 21",
                    "Item 22",
                    "Item 23",
                    "Item 24",
                    "Item 25",
                    "Item 26",
                    "Item 27",
                    "Item 28",
                    "Item 29"
                ]);
            });

            it ("scroll pos 90, nothing expanded", function() {
                scrollTo(90);
                Utils.assertItems([
                    "Item 90",
                    "Item 91",
                    "Item 92",
                    "Item 93",
                    "Item 94",
                    "Item 95",
                    "Item 96",
                    "Item 97",
                    "Item 98",
                    "Item 99"
                ]);
            });

            it ("scroll pos 100, past limit, doesn't break", function() {
                scrollTo(100);
                Utils.assertItems([
                    "Item 90",
                    "Item 91",
                    "Item 92",
                    "Item 93",
                    "Item 94",
                    "Item 95",
                    "Item 96",
                    "Item 97",
                    "Item 98",
                    "Item 99"
                ]);
            });

            it ("scroll pos 0, expanded Item 1", function() {
                Utils.toggleItem("Item 1");
                Utils.assertItems([
                    "Item 0",
                    "Item 1",
                    "-Item 1.0",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4",
                    "Item 2",
                    "Item 3",
                    "Item 4"
                ]);
            });

            it ("scroll pos 1, expanded Item 1 - All children in list", function() {
                Utils.toggleItem("Item 1");
                scrollTo(1);
                Utils.assertItems([
                    "Item 1",
                    "-Item 1.0",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4",
                    "Item 2",
                    "Item 3",
                    "Item 4",
                    "Item 5"
                ]);
            })

            it ("scroll pos 2, expanded Item 1 - All children but not parent in list", function() {
                Utils.toggleItem("Item 1");
                scrollTo(2);
                Utils.assertItems([
                    "-Item 1.0",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4",
                    "Item 2",
                    "Item 3",
                    "Item 4",
                    "Item 5",
                    "Item 6"
                ]);
            })

            it ("scroll pos 3, expanded Item 1 - Top not in list, bottom in list", function() {
                Utils.toggleItem("Item 1");
                scrollTo(3);
                Utils.assertItems([
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4",
                    "Item 2",
                    "Item 3",
                    "Item 4",
                    "Item 5",
                    "Item 6",
                    "Item 7"
                ]);
            })

            it ("scroll pos 7, expanded Item 1 - no children in list", function() {
                Utils.toggleItem("Item 1");
                scrollTo(7);
                Utils.assertItems([
                    "Item 2",
                    "Item 3",
                    "Item 4",
                    "Item 5",
                    "Item 6",
                    "Item 7",
                    "Item 8",
                    "Item 9",
                    "Item 10",
                    "Item 11"
                ]);
            })

            it ("scroll pos 9, expanded Item 1, expand 12 - partial children", function() {
                Utils.toggleItem("Item 1");
                scrollTo(9);
                Utils.toggleItem("Item 12");
                Utils.assertItems([
                    "Item 4",
                    "Item 5",
                    "Item 6",
                    "Item 7",
                    "Item 8",
                    "Item 9",
                    "Item 10",
                    "Item 11",
                    "Item 12",
                    "-Item 12.0"
                ]);
            })

            it ("scroll pos 19, expanded Item 1, expand 12 - middle of children", function() {
                Utils.toggleItem("Item 1");
                scrollTo(9);
                Utils.toggleItem("Item 12");
                scrollTo(19);
                Utils.assertItems([
                    "-Item 12.1",
                    "-Item 12.2",
                    "-Item 12.3",
                    "-Item 12.4",
                    "-Item 12.5",
                    "-Item 12.6",
                    "-Item 12.7",
                    "-Item 12.8",
                    "-Item 12.9",
                    "-Item 12.10",
                ]);
            })

            it ("scroll pos 19, expanded Item 1, expand 12, expand 12.5 - middle of children with all sub children", function() {
                Utils.toggleItem("Item 1");
                scrollTo(9);
                Utils.toggleItem("Item 12");
                scrollTo(19);
                Utils.toggleItem("Item 12.5");
                Utils.assertItems([
                    "-Item 12.1",
                    "-Item 12.2",
                    "-Item 12.3",
                    "-Item 12.4",
                    "-Item 12.5",
                    "--Item 12.5.0",
                    "--Item 12.5.1",
                    "-Item 12.6",
                    "-Item 12.7",
                    "-Item 12.8"
                ]);

                Utils.toggleItem("Item 12.5");    
                Utils.assertItems([
                    "-Item 12.1",
                    "-Item 12.2",
                    "-Item 12.3",
                    "-Item 12.4",
                    "-Item 12.5",
                    "-Item 12.6",
                    "-Item 12.7",
                    "-Item 12.8",
                    "-Item 12.9",
                    "-Item 12.10",
                ]);

                Utils.toggleItem("Item 12.5");
                scrollTo(90 + 20 + 5 + 2 - 1);
                // reduce by 1 so we don't overshoot
                Utils.assertItems([
                    "Item 89",
                    "Item 90",
                    "Item 91",
                    "Item 92",
                    "Item 93",
                    "Item 94",
                    "Item 95",
                    "Item 96",
                    "Item 97",
                    "Item 98"
                ]);
            });

            it ('multiple levels expanded, scrolling through them', function() {
                Utils.toggleItem("Item 1");
                Utils.toggleItem("Item 1.0");
                Utils.assertItems([
                    "Item 0",
                    "Item 1",
                    "-Item 1.0",
                    "--Item 1.0.0",
                    "--Item 1.0.1",
                    "--Item 1.0.2",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4"
                ]);
                scrollTo(1);
                Utils.assertItems([
                    "Item 1",
                    "-Item 1.0",
                    "--Item 1.0.0",
                    "--Item 1.0.1",
                    "--Item 1.0.2",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4",
                    "Item 2"
                ])
                scrollTo(2);
                Utils.assertItems([
                    "-Item 1.0",
                    "--Item 1.0.0",
                    "--Item 1.0.1",
                    "--Item 1.0.2",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4",
                    "Item 2",
                    "Item 3"
                ])
                scrollTo(3);
                Utils.assertItems([
                    "--Item 1.0.0",
                    "--Item 1.0.1",
                    "--Item 1.0.2",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4",
                    "Item 2",
                    "Item 3",
                    "Item 4"
                ])
                Utils.toggleItem("Item 1.3");
                Utils.assertItems([
                    "--Item 1.0.0",
                    "--Item 1.0.1",
                    "--Item 1.0.2",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "--Item 1.3.0",
                    "--Item 1.3.1",
                    "--Item 1.3.2",
                    "-Item 1.4"
                ])
            });

            it ("expanding above should recursively push down expanded stuff below", function() {
                Utils.toggleItem("Item 1");
                scrollTo(5);
                Utils.toggleItem("Item 1.3");
                scrollTo(0);
                Utils.toggleItem("Item 1.0");
                Utils.assertItems([
                    "Item 0",
                    "Item 1",
                    "-Item 1.0",
                    "--Item 1.0.0",
                    "--Item 1.0.1",
                    "--Item 1.0.2",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "--Item 1.3.0"
                ]);
                Utils.toggleItem("Item 1.3.0");
                scrollTo(1);
                Utils.assertItems([
                    "Item 1",
                    "-Item 1.0",
                    "--Item 1.0.0",
                    "--Item 1.0.1",
                    "--Item 1.0.2",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "--Item 1.3.0",
                    "---Item 1.3.0.0"
                ]);
                Utils.toggleItem("Item 1.0");
                Utils.assertItems([
                    "Item 1",
                    "-Item 1.0",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "--Item 1.3.0",
                    "---Item 1.3.0.0",
                    "---Item 1.3.0.1",
                    "---Item 1.3.0.2",
                    "--Item 1.3.1"
                ]);
                Utils.toggleItem("Item 1.0");
                Utils.assertItems([
                    "Item 1",
                    "-Item 1.0",
                    "--Item 1.0.0",
                    "--Item 1.0.1",
                    "--Item 1.0.2",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "--Item 1.3.0",
                    "---Item 1.3.0.0"
                ]);
                Utils.toggleItem("Item 1");
                Utils.assertItems([
                    "Item 1",
                    "Item 2",
                    "Item 3",
                    "Item 4",
                    "Item 5",
                    "Item 6",
                    "Item 7",
                    "Item 8",
                    "Item 9",
                    "Item 10"
                ]);
                Utils.toggleItem("Item 1");
                Utils.assertItems([
                    "Item 1",
                    "-Item 1.0",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "-Item 1.4",
                    "Item 2",
                    "Item 3",
                    "Item 4",
                    "Item 5"
                ])
                Utils.toggleItem("Item 1.3");
                Utils.assertItems([
                    "Item 1",
                    "-Item 1.0",
                    "-Item 1.1",
                    "-Item 1.2",
                    "-Item 1.3",
                    "--Item 1.3.0",
                    "--Item 1.3.1",
                    "--Item 1.3.2",
                    "-Item 1.4",
                    "Item 2"
                ])
            });

        });

        
        describe ("singleRootItem + getData and different scroll positions", function() {

