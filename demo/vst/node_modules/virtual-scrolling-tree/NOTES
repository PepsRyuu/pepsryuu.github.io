                Utils.assertItems([
                    "Item 0",
                    "-Item 0.0",
                    "-Item 0.1",
                    "-Item 0.2",
                    "-Item 0.3",
                    "-Item 0.4"
                ]);
            });
        });

        describe ("twoRootItems + getData and different scroll positions", function() {

            beforeEach(function() {
                tree = new Tree({
                    getData: Utils.getData.bind(window, twoRootNodeData),
                    totalRootItems: 2
                });

                tree.attachTo(core.Element.wrap(bitContainer));
            });

            afterEach(function() {
                tree.destroy();
            })

            it("should show the tree normally", function() {
                expect(document.querySelectorAll(".elDataviz-Item").length).to.equal(2);
