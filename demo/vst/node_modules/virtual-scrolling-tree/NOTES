        describe("Misc", function() {
            it ("CDS-5849 ScrollBar bug fix test for Firefox", function(done) {
                tree = new Tree({
                    getData: Utils.getData.bind(window, fiveRootNodeData),
                    totalRootItems: 5
                });
                tree.attachTo(core.Element.wrap(bitContainer));

                Utils.toggleItem("Item 0"); 
                Utils.toggleItem("Item 4");
                Utils.skipFrame(function() {
                    scrollTo(10);
                    // Skipping frame doesn't trigger the issue. Have to skip
                    // a decent amount of time for this issue to take effect.
                    // This is the display: none scrollbar issue from the VSB.
                    // Testing it here so that the tree isn't affected in the future.
                    setTimeout(function() {
                        Utils.toggleItem("Item 4");
                        Utils.skipFrame(function() {
                            expect(document.querySelectorAll(".elDataviz-Item").length).to.equal(8);
                            Utils.assertItems([
                                "Item 0",
                                "-Item 0.0",
                                "-Item 0.1",
                                "-Item 0.2",
                                "Item 1",
                                "Item 2",
                                "Item 3",
                                "Item 4"
                            ]);
                            tree.destroy();
                            done();
                        });
                    }, 300);
                })
                
            });
        });

        describe("Checkboxes", function() {
            beforeEach(function() {
                tree = new Tree({
                    getData: Utils.getData.bind(window, data),
                    totalRootItems: 100,
                    checkboxes: true
                });

                tree.attachTo(core.Element.wrap(bitContainer));
            });

            afterEach(function() {
                tree.destroy();
            })

            it ("checking a checkbox should trigger a checkend with all of the ids for items that are currently checked", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("checkend", callback);
                Utils.checkItem("Item 0");
                Utils.skipFrame(function() {
                    expect(callback.calledWith(["Item 0"])).to.be.true;
                    Utils.checkItem("Item 1");

                    Utils.skipFrame(function() {
                        scrollTo(90);
                        Utils.checkItem("Item 90");
                        Utils.skipFrame(function() {
                            expect(callback.calledWith(["Item 0", "Item 1", "Item 90"])).to.be.true;
                            done();
                        });
                    });
                });
            });

            it ("unchecking should also trigger a checkend with the updated list of checked items", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("checkend", callback);
                Utils.checkItem("Item 0");

                Utils.skipFrame(function() {
                    expect(callback.calledWith(["Item 0"])).to.be.true;
                    Utils.checkItem("Item 0");
                    Utils.skipFrame(function() {
                        expect(callback.calledWith([])).to.be.true;
                        done();
                    })
                })
            });

            it ("check an item, scroll it out of view, scroll back up, should still be checked", function(done) {
                var callback = sinon.spy();
                Utils.checkItem("Item 0");
                Utils.skipFrame(function() {
                    scrollTo(90);
                    var el = document.querySelector(".ebCheckbox");
                    expect(el.checked).to.be.false;
                    scrollTo(0);
                    el = document.querySelector(".ebCheckbox");
                    expect(el.checked).to.be.true;
                    done();
                })
            })
        });

        describe ("Selection", function() {
            beforeEach(function() {
                tree = new Tree({
                    getData: Utils.getData.bind(window, data),
                    totalRootItems: 100,
                    selectable: true
                });

                tree.attachTo(core.Element.wrap(bitContainer));
            });

            afterEach(function() {
                tree.destroy();
            })

            it ("selecting a row should trigger a selectend event", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.assertSelected("Item 0", true);
                    expect(callback.calledWith(["Item 0"])).to.be.true;
                    done();
                })
            });

            it ("select a row, select the same row again, should be unselected (two selectend events)", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.assertSelected("Item 0", true);
                    expect(callback.calledWith(["Item 0"])).to.be.true;
                    Utils.selectItem("Item 0");

                    Utils.skipFrame(function() {
                        Utils.assertSelected("Item 0", false);
                        expect(callback.calledWith([])).to.be.true;
                        done();
                    });
                })
            });

            it ("select a row, select a different one, prev row should be unselected with new one selected, and 1 selectend event", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 1");

                    Utils.skipFrame(function() {
                        Utils.assertSelected("Item 0", false);
                        Utils.assertSelected("Item 1", true);
                        expect(callback.calledWith(["Item 1"])).to.be.true;
                        expect(callback.callCount).to.equal(2);
                        done();
                    });
                })
            });

            it ("select a row, scroll it out of view, scroll back up, should still be selected", function(done) {
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    scrollTo(90);
                    var el = document.querySelector(".elDataviz-Item_selected");
                    expect(el).to.be.null;
                    scrollTo(0);
                    el = document.querySelector(".elDataviz-Item_selected");
                    expect(el).not.to.be.null;
                    Utils.assertSelected("Item 0", true);
                    done();
                });
            });

            it ("select a row, scroll it out of view, select another, scroll up, prev one should be unselected", function (done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    scrollTo(90);
                    Utils.selectItem("Item 90");
                    Utils.skipFrame(function() {
                        Utils.assertSelected("Item 90", true);
                        expect(callback.calledWith(["Item 90"])).to.be.true;
                        scrollTo(0);
                        Utils.assertSelected("Item 0", false);
                        done();
                    });
                });
            });
        })

        describe ("MultiSelect", function() {
            beforeEach(function() {
                tree = new Tree({
                    getData: Utils.getData.bind(window, data),
                    getIds: function(query, success, error) {
                        Utils.getData.call(window, data, query, success, error, true);
                    },
                    totalRootItems: 100,
                    selectable: true,
                    multiselect: true
                });

                tree.attachTo(core.Element.wrap(bitContainer));
            });

            afterEach(function() {
                tree.destroy();
            })

            it ("select Item 0, shift click to Item 5, all 5 items should be selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 5", {shiftKey: true});
                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 0", "Item 1", "Item 2", "Item 3", "Item 4", "Item 5"])).to.be.true;
                        done();
                    })
                })
            });

            it ("select Item 3, shift click to Item 5, shift click to Item 0, Item 0-3 should be selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 3");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 5", {shiftKey: true});
                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 3", "Item 4", "Item 5"])).to.be.true;
                        Utils.selectItem("Item 0", {shiftKey: true});
                        Utils.skipFrame(function() {
                            expect(callback.calledWith(["Item 0", "Item 1", "Item 2", "Item 3"])).to.be.true;
                            done();
                        })
                        
                    })
                })
            });

            it ("select Item 0, select Item 1, should only have Item 1 selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 1");
                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 1"])).to.be.true;
                        Utils.assertSelected("Item 0", false);
                        Utils.assertSelected("Item 1", true);
                        done();
                    })
                })
            });

            it ("select Item 0, select it again, nothing should be selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 0");
                    Utils.skipFrame(function() {
                        expect(callback.calledWith([])).to.be.true;
                        Utils.assertSelected("Item 0", false);
                        done();
                    })
                })
            });

            it ("select Item 0, ctrl click to Item 3, ctrl click Item 5, Item 0,3,5 should be selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 3", {ctrlKey: true});
                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 0", "Item 3"])).to.be.true;
                        Utils.assertSelected("Item 0", true);
                        Utils.assertSelected("Item 3", true);
                        Utils.selectItem("Item 5", {ctrlKey: true});
                        Utils.skipFrame(function() {
                            expect(callback.calledWith(["Item 0", "Item 3", "Item 5"])).to.be.true;
                            done();
                        })
                    })
                })
            });

            it ("select Item 0, shift click Item 5, ctrl click Item 3, 4 items should be selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 5", {shiftKey: true});
                    Utils.skipFrame(function() {
                        Utils.selectItem("Item 3", {ctrlKey: true});
                        Utils.skipFrame(function() {
                            expect(callback.calledWith(["Item 0", "Item 1", "Item 2", "Item 4", "Item 5"])).to.be.true;
                            Utils.assertSelected("Item 0", true);
                            Utils.assertSelected("Item 1", true);
                            Utils.assertSelected("Item 2", true);
                            Utils.assertSelected("Item 3", false);
                            Utils.assertSelected("Item 4", true);
                            Utils.assertSelected("Item 5", true);
                            done();
                        })
                    })
                })
            });

            it ("select Item 0, shift click to Item 5, normal click on Item 3, only Item 3 should be selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 5", {shiftKey: true});
                    Utils.skipFrame(function() {
                        Utils.selectItem("Item 3");
                        Utils.skipFrame(function() {
                            expect(callback.calledWith(["Item 3"])).to.be.true;
                            Utils.assertSelected("Item 0", false);
                            Utils.assertSelected("Item 1", false);
                            Utils.assertSelected("Item 2", false);
                            Utils.assertSelected("Item 3", true);
                            Utils.assertSelected("Item 4", false);
                            Utils.assertSelected("Item 5", false);
                            done();
                        })
                    })
                })
            });

            it ("select Item 0, scroll it out of view, ctrl click Item 12, selectend should contain both, scroll up and Item 0 should be okay", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    scrollTo(12);
                    Utils.selectItem("Item 12", {ctrlKey: true});
                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 0", "Item 12"])).to.be.true;
                        Utils.assertSelected("Item 12", true);
                        scrollTo(0);
                        Utils.assertSelected("Item 0", true);
                        done();
                    })
                })
            });

            it ("select Item 0, scroll it out of view, shift click Item 12, selectend should contain everything between them", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    scrollTo(12);
                    Utils.selectItem("Item 12", {shiftKey: true});
                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 0", "Item 1", "Item 2", "Item 3", "Item 4", "Item 5", "Item 6", "Item 7", "Item 8", "Item 9", "Item 10", "Item 11", "Item 12"])).to.be.true;
                        Utils.assertSelected("Item 12", true);
                        scrollTo(0);
                        Utils.assertSelected("Item 0", true);
                        Utils.assertSelected("Item 1", true);
                        Utils.assertSelected("Item 2", true);
                        Utils.assertSelected("Item 3", true);
                        Utils.assertSelected("Item 4", true);
                        Utils.assertSelected("Item 5", true);
                        done();
                    })
                })
            });

            it ("select Item 1 and expand it, shift click to Item 3, all items including the children should be selected", function (done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 1");
                Utils.toggleItem("Item 1");
                Utils.skipFrame(function() {
                    Utils.selectItem("Item 3", {shiftKey: true});
                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 1", "Item 1.0", "Item 1.1", "Item 1.2", "Item 1.3", "Item 1.4", "Item 2", "Item 3"])).to.be.true;
                        Utils.assertSelected("Item 1", true);
                        Utils.assertSelected("Item 1.0", true);
                        Utils.assertSelected("Item 1.1", true);
                        Utils.assertSelected("Item 1.2", true);
                        Utils.assertSelected("Item 1.3", true);
                        Utils.assertSelected("Item 1.4", true);
                        Utils.assertSelected("Item 2", true);
                        Utils.assertSelected("Item 3", true);
                        done();
                    })
                })
            });

            it ("select Item 1 and expand it, scroll it out of view, shift click Item 12, all items should be selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 1");
                Utils.toggleItem("Item 1");
                Utils.skipFrame(function() {
                    scrollTo(12 + 5) // Item 12
                    Utils.selectItem("Item 12", {shiftKey: true});
                    Utils.skipFrame(function() {
                        expect(callback.calledWith([
                            "Item 1", 
                            "Item 2", 
                            "Item 3",
                            "Item 4",
                            "Item 5",
                            "Item 6",
                            "Item 7",
                            "Item 8",
                            "Item 9",
                            "Item 10",
                            "Item 11",
                            "Item 12",
                            "Item 1.0", 
                            "Item 1.1", 
                            "Item 1.2", 
                            "Item 1.3", 
                            "Item 1.4"
                        ])).to.be.true;
                        Utils.assertSelected("Item 12", true);
                        scrollTo(0);
                        Utils.assertSelected("Item 0", false);
                        Utils.assertSelected("Item 1", true);
                        Utils.assertSelected("Item 1.0", true);
                        Utils.assertSelected("Item 1.1", true);
                        Utils.assertSelected("Item 2", true);
                        done();
                    })
                })
            });

            it ("scroll to Item 1, expand it, expand Item 1.3, expand Item 1.3.0, select Item 0, scroll to Item 3 and select, all should be selected", function(done) {
                var callback = sinon.spy();
                tree.addEventHandler("selectend", callback);
                Utils.selectItem("Item 1");
                Utils.toggleItem("Item 1");
                Utils.toggleItem("Item 1.3");
                Utils.toggleItem("Item 1.3.0");
                Utils.skipFrame(function() {
                    scrollTo(3 + 5 + 3 + 3) // Item 3
                    Utils.selectItem("Item 3", {shiftKey: true});
                    Utils.skipFrame(function() {
                        expect(callback.calledWith([
                            "Item 1", 
                            "Item 2", 
                            "Item 3",
                            "Item 1.0", 
                            "Item 1.1", 
                            "Item 1.2", 
                            "Item 1.3", 
                            "Item 1.4",
                            "Item 1.3.0",
                            "Item 1.3.1",
                            "Item 1.3.2",
                            "Item 1.3.0.0",
                            "Item 1.3.0.1",
                            "Item 1.3.0.2"
                        ])).to.be.true;
                        done();
                    })
                });
            });
        });

        describe ("Bind", function() {
            beforeEach(function() {
                tree = new Tree({
                    getData: Utils.getData.bind(window, data),
                    getIds: function(query, success, error) {
                        Utils.getData.call(window, data, query, success, error, true);
                    },
                    totalRootItems: 100,
                    checkboxes: true,
                    selectable: true,
                    multiselect: true,
                    bindselect: true
                });

                tree.attachTo(core.Element.wrap(bitContainer));
            });

            afterEach(function() {
                tree.destroy();
            })

            it ("checking a checkbox should do a select, and trigger both checkend and selectend", function(done) {
                var checkCallback = sinon.spy();
                var selectCallback = sinon.spy();
                tree.addEventHandler("selectend", selectCallback);
                tree.addEventHandler("checkend", checkCallback);
                Utils.checkItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.assertSelected("Item 0", true);
                    Utils.assertChecked("Item 0", true);
                    expect(checkCallback.calledWith(["Item 0"])).to.be.true;
                    expect(selectCallback.calledWith(["Item 0"])).to.be.true;
                    expect(checkCallback.callCount).to.equal(1);
                    expect(selectCallback.callCount).to.equal(1);
                    done();
                })
            });

            it ("selecting should check the checkbox, and trigger both checkend and selectend", function(done) {
                var checkCallback = sinon.spy();
                var selectCallback = sinon.spy();
                tree.addEventHandler("selectend", selectCallback);
                tree.addEventHandler("checkend", checkCallback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    Utils.assertSelected("Item 0", true);
                    Utils.assertChecked("Item 0", true);
                    expect(checkCallback.calledWith(["Item 0"])).to.be.true;
                    expect(selectCallback.calledWith(["Item 0"])).to.be.true;
                    expect(checkCallback.callCount).to.equal(1);
                    expect(selectCallback.callCount).to.equal(1);
                    done();
                })
            });

            it ("select Item 0, scroll it out of view, shift click, all checkboxes should be selected", function(done) {
                var checkCallback = sinon.spy();
                var selectCallback = sinon.spy();
                tree.addEventHandler("selectend", selectCallback);
                tree.addEventHandler("checkend", checkCallback);
                Utils.selectItem("Item 0");
                Utils.skipFrame(function() {
                    scrollTo(1);
                    Utils.selectItem("Item 3", {shiftKey: true});
                    Utils.skipFrame(function() {
                        scrollTo(0);
                        Utils.skipFrame(function() {
                            Utils.assertSelected("Item 0", true);
                            Utils.assertSelected("Item 1", true);
                            Utils.assertSelected("Item 2", true);
                            Utils.assertSelected("Item 3", true);
                            Utils.assertChecked("Item 0", true);
                            Utils.assertChecked("Item 1", true);
                            Utils.assertChecked("Item 2", true);
                            Utils.assertChecked("Item 3", true);
                            expect(checkCallback.calledWith(["Item 0", "Item 1", "Item 2", "Item 3"])).to.be.true;
                            expect(selectCallback.calledWith(["Item 0", "Item 1", "Item 2", "Item 3"])).to.be.true;
                            expect(checkCallback.callCount).to.equal(2);
                            expect(selectCallback.callCount).to.equal(2);
                            done();
                        })
                        
                    })
                    
                })
            })
        });

        describe("Custom ItemType", function() {
            it ("should allow custom itemtype for labels", function(done) {

                var MyItemType = core.Widget.extend({
                    onViewReady: function() {
                        this.getElement().setAttribute("class", "MyCustomContentClass");
                        this.getElement().setText("CustomContent: " + this.options.label + ", " + this.options.id);
                    }
                });

                var tree = new Tree({
                    getData: Utils.getData.bind(window, data),
                    checkboxes: true,
                    totalRootItems: 100,
                    itemType: MyItemType
                });

                tree.attachTo(core.Element.wrap(bitContainer));

                var els = bitContainer.querySelectorAll(".MyCustomContentClass");
                expect(els.length).to.equal(10);
                expect(els[0].textContent).to.equal("CustomContent: Item 0, Item 0");
                expect(els[1].textContent).to.equal("CustomContent: Item 1, Item 1");

                tree.getVirtualScrollBar().setPosition(1);
                tree.redraw();
                var els = bitContainer.querySelectorAll(".MyCustomContentClass");
                expect(els.length).to.equal(10);
                expect(els[0].textContent).to.equal("CustomContent: Item 1, Item 1");
                expect(els[1].textContent).to.equal("CustomContent: Item 2, Item 2");

                tree.destroy();
                done();
            });
        });

        describe("Events", function() {
            beforeEach(function() {
                tree = new Tree({
                    getData: Utils.getData.bind(window, data),
                    totalRootItems: 100
                });

                tree.attachTo(core.Element.wrap(bitContainer));
            });

            afterEach(function() {
                tree.destroy();
            })

            describe("expand", function() {
                it("should trigger when an item is expanded, passing object as argument", function(done) {
                    var expandSpy = sinon.spy();
                    tree.addEventHandler("expand", expandSpy);
                    Utils.toggleItem("Item 1");
                    Utils.skipFrame(function() {
                        expect(expandSpy.callCount).to.equal(1);
                        expect(expandSpy.calledWith({
                            id: "Item 1",
                            parent: null,
                            offset: 1,
                            children: 5
                        })).to.be.true;

                        Utils.toggleItem("Item 1.0");
                        Utils.skipFrame(function() {
                            expect(expandSpy.callCount).to.equal(2);
                            expect(expandSpy.calledWith({
                                id: "Item 1.0",
                                parent: "Item 1",
                                offset: 0,
                                children: 3
                            })).to.be.true;
                            done();
                        });
                    });
                });
            });

            describe("collapse", function() {
                it ("should trigger when an item is collapsed, passing object as argument", function(done) {
                    var collapseSpy = sinon.spy();
                    tree.addEventHandler("collapse", collapseSpy);
                    Utils.toggleItem("Item 1");
                    Utils.skipFrame(function() {
                        expect(collapseSpy.callCount).to.equal(0);
                        Utils.toggleItem("Item 1");
                        Utils.skipFrame(function() {
                            expect(collapseSpy.callCount).to.equal(1);
                            expect(collapseSpy.calledWith({
                                id: "Item 1"
                            })).to.be.true;
                            done();
                        });
                    });
                });

                it ("should trigger recursively for all sub-items as well", function(done) {
                    var collapseSpy = sinon.spy();
                    tree.addEventHandler("collapse", collapseSpy);
                    Utils.toggleItem("Item 1");
                    Utils.toggleItem("Item 1.3");
                    Utils.toggleItem("Item 1.3.0");
                    Utils.toggleItem("Item 1");
                    Utils.skipFrame(function() {
                        expect(collapseSpy.callCount).to.equal(3);
                        expect(collapseSpy.calledWith({id: "Item 1"})).to.be.true;
                        expect(collapseSpy.calledWith({id: "Item 1.3"})).to.be.true;
                        expect(collapseSpy.calledWith({id: "Item 1.3.0"})).to.be.true;
                        done();
                    });
                });
            });

            describe("domattach", function() {
                it ('should trigger when tree is attached to the DOM', function(done) {
                    var eventspy = sinon.spy();
                    tree.destroy();

                    tree = new Tree({
                        getData: Utils.getData.bind(window, data),
                        totalRootItems: 100
                    });

                    tree.addEventHandler('domattach', eventspy);
                    var el = new core.Element('div');
                    tree.attachTo(el);

                    setTimeout(function() {
                        expect(eventspy.callCount).to.equal(0);
                        core.Element.wrap(bitContainer).append(el);

                        setTimeout(function() {
                            expect(eventspy.callCount).to.equal(1);
                            done();
                        }, 100);
                    }, 100);
                })
            });
        });

        describe("Methods", function() {

            var createTree = function(options) {
                tree = new Tree({
                    getData: Utils.getData.bind(window, data),
                    getIds: function(query, success, error) {
                        Utils.getData.call(window, data, query, success, error, true);
                    },
                    checkboxes: options.checkboxes,
                    selectable: options.selectable,
                    bindselect: options.bindselect,
                    totalRootItems: 100
                })
                tree.attachTo(core.Element.wrap(bitContainer));

            }

            afterEach(function() {
                tree.destroy();
            })

            describe("Number getVisibleItemCount()", function() {
                it ("should return the visible number of items in the viewport", function(done) {
                    createTree({});
                    expect(tree.getVisibleItemCount()).to.equal(10);
                    var _window = document.querySelector("#window");
                    var originalHeight = _window.offsetHeight;
                    _window.style.minHeight = originalHeight - (32 * 5) + "px";
                    tree.redraw();
                    Utils.skipFrame(function() {
                        expect(tree.getVisibleItemCount()).to.equal(5);
                        _window.style.minHeight = '';
                        done();
                    })
                });
            });

            describe("check(Array<Number> ids)", function() {
                it ("checking items that are visible should receive the check", function(done) {
                    createTree({checkboxes: true})
                    tree.check(["Item 0", "Item 1", "Item 4"]);

                    Utils.skipFrame(function() {
                        Utils.assertChecked("Item 0", true);
                        Utils.assertChecked("Item 1", true);
                        Utils.assertChecked("Item 2", false);
                        Utils.assertChecked("Item 3", false);
                        Utils.assertChecked("Item 4", true);
                        done();
                    });
                    
                });

                it ("checking items outside of viewport should be checked when we scroll to them", function(done) {
                    createTree({checkboxes: true})
                    tree.check(["Item 12"]);

                    Utils.skipFrame(function() {
                        scrollTo(12);
                        Utils.assertChecked("Item 12", true);
                        done();
                    });
                });

                it ("should trigger checkend event", function (done) {
                    createTree({checkboxes: true});
                    var callback = sinon.spy();
                    tree.addEventHandler("checkend", callback);
                    tree.check(["Item 12"]);

                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 12"])).to.be.true;
                        done();
                    })
                });

                it ("if bind, should also select the rows and trigger selectend", function(done) {
                    createTree({checkboxes: true, selectable: true, bindselect: true});
                    var checkCallback = sinon.spy();
                    var selectCallback = sinon.spy();
                    tree.addEventHandler("checkend", checkCallback);
                    tree.addEventHandler("selectend", selectCallback);
                    tree.check(["Item 0"]);

                    Utils.skipFrame(function() {
                        Utils.assertChecked("Item 0", true);
                        Utils.assertSelected("Item 0", true);
                        expect(checkCallback.calledWith(["Item 0"])).to.be.true;
                        expect(selectCallback.calledWith(["Item 0"])).to.be.true;
                        done();
                    })
                });
            });

            describe("select(Array<Number> ids)", function() {
                it ("selecting items that are visible should look selected", function(done) {
                    createTree({selectable: true})
                    tree.select(["Item 0", "Item 1", "Item 4"]);

                    Utils.skipFrame(function() {
                        Utils.assertSelected("Item 0", true);
                        Utils.assertSelected("Item 1", true);
                        Utils.assertSelected("Item 2", false);
                        Utils.assertSelected("Item 3", false);
                        Utils.assertSelected("Item 4", true);
                        done();
                    });

                });

                it ("selecting items outside of viewport should be selected when we scroll to them", function(done) {
                    createTree({selectable: true})
                    tree.select(["Item 12"]);

                    Utils.skipFrame(function() {
                        scrollTo(12);
                        Utils.assertSelected("Item 12", true);
                        done();
                    });
                });

                it ("should trigger selectend event", function(done) {
                    createTree({selectable: true});
                    var callback = sinon.spy();
                    tree.addEventHandler("selectend", callback);
                    tree.select(["Item 12"]);

                    Utils.skipFrame(function() {
                        expect(callback.calledWith(["Item 12"])).to.be.true;
                        done();
                    })
                });

                it ("if bind, should also check the rows and trigger checkend", function(done) {
                    createTree({checkboxes: true, selectable: true, bindselect: true});
                    var checkCallback = sinon.spy();
                    var selectCallback = sinon.spy();
                    tree.addEventHandler("checkend", checkCallback);
                    tree.addEventHandler("selectend", selectCallback);
                    tree.select(["Item 0"]);

                    Utils.skipFrame(function() {
                        Utils.assertChecked("Item 0", true);
                        Utils.assertSelected("Item 0", true);
                        expect(checkCallback.calledWith(["Item 0"])).to.be.true;
                        expect(selectCallback.calledWith(["Item 0"])).to.be.true;
                        done();
                    })
                });
            });

            describe("uncheckAll()", function() {
                it ("should visibly remove the check from all items", function(done) {
                    createTree({checkboxes: true})
                    tree.check(["Item 0", "Item 1", "Item 4"]);

                    Utils.skipFrame(function() {
                        tree.uncheckAll();
                        Utils.assertChecked("Item 0", false);
                        Utils.assertChecked("Item 1", false);
                        Utils.assertChecked("Item 4", false);
                        done();
                    });
                });

                it ("should trigger the checkend event", function(done) {
                    createTree({checkboxes: true});
                    var callback = sinon.spy();
                    tree.addEventHandler("checkend", callback);
                    tree.check(["Item 12"]);

                    Utils.skipFrame(function() {
                        tree.uncheckAll();
                        Utils.skipFrame(function() {
                            expect(callback.calledWith([])).to.be.true;
                            expect(callback.callCount).to.equal(2);
                            done();
                        })
                    })
                });

                it ("if bind, should also trigger the selectend event and unselect items", function(done) {
                    createTree({checkboxes: true, selectable: true, bindselect: true});
                    var checkCallback = sinon.spy();
                    var selectCallback = sinon.spy();
                    tree.addEventHandler("checkend", checkCallback);
                    tree.addEventHandler("selectend", selectCallback);
                    tree.check(["Item 0"]);

                    Utils.skipFrame(function() {
                        tree.uncheckAll();
                        Utils.skipFrame(function() {
                            expect(checkCallback.calledWith([])).to.be.true;
                            expect(selectCallback.calledWith([])).to.be.true;
                            Utils.assertChecked("Item 0", false);
                            Utils.assertSelected("Item 0", false);
                            done();
                        })
                    })
                });
            });

            describe("unselectAll()", function() {
                it ("should visibly remove the select from all items", function(done) {
                    createTree({selectable: true})
                    tree.select(["Item 0", "Item 1", "Item 4"]);

                    Utils.skipFrame(function() {
                        tree.unselectAll();
                        Utils.assertSelected("Item 0", false);
                        Utils.assertSelected("Item 1", false);
                        Utils.assertSelected("Item 4", false);
                        done();
                    });
                });

                it ("should trigger the selectend event", function(done) {
                    createTree({selectable: true});
                    var callback = sinon.spy();
                    tree.addEventHandler("selectend", callback);
                    tree.select(["Item 12"]);

                    Utils.skipFrame(function() {
                        tree.unselectAll();
                        Utils.skipFrame(function() {
                            expect(callback.calledWith([])).to.be.true;
                            expect(callback.callCount).to.equal(2);
                            done();
                        })
                    })

                });

                it ("if bind, should also trigger the checkend event and uncheck items", function(done) {
                    createTree({checkboxes: true, selectable: true, bindselect: true});
                    var checkCallback = sinon.spy();
                    var selectCallback = sinon.spy();
                    tree.addEventHandler("checkend", checkCallback);
                    tree.addEventHandler("selectend", selectCallback);
                    tree.select(["Item 0"]);

                    Utils.skipFrame(function() {
                        tree.unselectAll();
                        Utils.skipFrame(function() {
                            expect(checkCallback.calledWith([])).to.be.true;
                            expect(selectCallback.calledWith([])).to.be.true;
                            Utils.assertChecked("Item 0", false);
                            Utils.assertSelected("Item 0", false);
                            done();
                        })
                    })
                });
            });

            describe("expand(Object item)", function() {
                it ("if item is in view, should expand the item", function(done) {
                    createTree({});
                    tree.expand({
                        id: "Item 1",
                        parent: null,
                        children: 5,
                        offset: 1
                    });

                    Utils.assertItems([
                        "Item 0",
                        "Item 1",
                        "-Item 1.0",
                        "-Item 1.1",
                        "-Item 1.2",
                        "-Item 1.3",
                        "-Item 1.4",
                        "Item 2",
                        "Item 3",
                        "Item 4"
                    ]);
                    done();
                });

                it ("should throw error if parent is not expanded", function() {
                    createTree({});
                    expect(function() {
                        tree.expand({
                            id: "Item 1.0",
                            parent: "Item 1",
                            offset: 0,
                            children: 3
                        });

                    }).to.throw(Error);
                });

                it ("if item is not in view, should be able to see it expanded if we scroll down", function(done) {
                    createTree({});
                    tree.expand({
                        id: "Item 12",
                        offset: 12,
                        children: 20,
                        parent: null
                    });

                    scrollTo(12);
                    Utils.assertItems([
                        "Item 12",
                        "-Item 12.0",
                        "-Item 12.1",
                        "-Item 12.2",
                        "-Item 12.3",
                        "-Item 12.4",
                        "-Item 12.5",
                        "-Item 12.6",
                        "-Item 12.7",
                        "-Item 12.8"
                    ]);
                    done();
                });
                
                it ("should trigger the expand event", function() {
                    createTree({});
                    var expandSpy = sinon.spy();
                    tree.addEventHandler("expand", expandSpy);
                    var arg = {
                        id: "Item 1",
                        offset: 1,
                        children: 5,
                        parent: null
                    };
                    tree.expand(arg);
                    expect(expandSpy.callCount).to.equal(1);
                    expect(expandSpy.calledWith(arg)).to.be.true;
                });

                it ("should not trigger expand if it's already expanded", function() {
                    createTree({});
                    var expandSpy = sinon.spy();
                    tree.addEventHandler("expand", expandSpy);
                    var arg = {
                        id: "Item 1",
                        offset: 1,
                        children: 5,
                        parent: null
                    };
                    tree.expand(arg);
                    expect(expandSpy.callCount).to.equal(1);
                    expect(expandSpy.calledWith(arg)).to.be.true;
                    tree.expand(arg);
                    expect(expandSpy.callCount).to.equal(1);
                });
                
                it ("should allow children of expanded items to be expanded", function() {
                    createTree({});
                    tree.expand({
                        id: "Item 12",
                        children: 20,
                        offset: 12,
                        parent: null
                    });
                    tree.expand({
                        id: "Item 12.5",
                        offset: 5,
                        children: 2,
                        parent: "Item 12"
                    });

                    scrollTo(10);
                    Utils.assertItems([
                        "Item 10",
                        "Item 11",
                        "Item 12",
                        "-Item 12.0",
                        "-Item 12.1",
                        "-Item 12.2",
                        "-Item 12.3",
                        "-Item 12.4",
                        "-Item 12.5",
                        "--Item 12.5.0",
                        "--Item 12.5.1"
                    ]);
                    scrollTo(11);
                    Utils.assertItems([
                        "Item 11",
                        "Item 12",
                        "-Item 12.0",
                        "-Item 12.1",
                        "-Item 12.2",
                        "-Item 12.3",
                        "-Item 12.4",
                        "-Item 12.5",
                        "--Item 12.5.0",
                        "--Item 12.5.1",
                        "-Item 12.6"
                    ]);
                });

            });

            describe("collapse(Object item)", function() {
                it ("if item is in view, should collapse the item", function(done) {
                    createTree({});
                    Utils.toggleItem("Item 1");
                    Utils.skipFrame(function() {
                        Utils.assertItems([
                            "Item 0",
                            "Item 1",
                            "-Item 1.0",
                            "-Item 1.1",
                            "-Item 1.2",
                            "-Item 1.3",
                            "-Item 1.4",
                            "Item 2",
                            "Item 3",
                            "Item 4"
                        ]);
                        tree.collapse({
                            id: "Item 1",
                            parent: null,
                            children: 5,
                            offset: 1
                        });

                        Utils.assertItems([
                            "Item 0",
                            "Item 1",
                            "Item 2",
                            "Item 3",
                            "Item 4",
                            "Item 5",
                            "Item 6",
                            "Item 7",
                            "Item 8",
                            "Item 9"
                        ]);
                        done();
                    });
                    
                });

                it ("if item is not in view, should be able to see it collapsed if we scroll down", function(done) {
                    createTree({});
                    scrollTo(12);
                    Utils.toggleItem("Item 12");
                    Utils.assertItems([
                        "Item 12",
                        "-Item 12.0",
                        "-Item 12.1",
                        "-Item 12.2",
                        "-Item 12.3",
                        "-Item 12.4",
                        "-Item 12.5",
                        "-Item 12.6",
                        "-Item 12.7",
                        "-Item 12.8"
                    ]);
                    scrollTo(0);
                    tree.collapse({
                        id: "Item 12",
                        children: 20,
                        offset: 12,
                        parent: null
                    });
                    scrollTo(12);
                    Utils.assertItems([
                        "Item 12",
                        "Item 13",
                        "Item 14",
                        "Item 15",
                        "Item 16",
                        "Item 17",
                        "Item 18",
                        "Item 19",
                        "Item 20",
                        "Item 21"
                    ]);
                    done();
                });
                
                it ("should trigger the collapse event", function(done) {
                    createTree({});
                    var collapseSpy = sinon.spy();
                    tree.addEventHandler("collapse", collapseSpy);
                    var arg = {
                        id: "Item 1",
                        offset: 1,
                        children: 5,
                        parent: null
                    };
                    Utils.toggleItem("Item 1");
                    tree.collapse(arg);
                    expect(collapseSpy.callCount).to.equal(1);
                    expect(collapseSpy.calledWith({
                        id: arg.id
                    })).to.be.true;
                    done();
                });

                it ("should not trigger collapse if it's already collapsed", function(done) {
                    createTree({});
                    var collapseSpy = sinon.spy();
                    tree.addEventHandler("collapse", collapseSpy);
                    var arg = {
                        id: "Item 1",
                        offset: 1,
                        children: 5,
                        parent: null
                    };
                    Utils.toggleItem("Item 1");
                    tree.collapse(arg);
                    expect(collapseSpy.callCount).to.equal(1);
                    expect(collapseSpy.calledWith({
                        id: arg.id
                    })).to.be.true;
                    tree.collapse(arg);
                    expect(collapseSpy.callCount).to.equal(1);
                    done();
                });
                
                it ("should collapse children of nested items", function(done) {
                    createTree({});
                    var collapseSpy = sinon.spy();
                    tree.addEventHandler("collapse", collapseSpy);
                    tree.expand({
                        id: "Item 12",
                        children: 20,
                        offset: 12,
                        parent: null
                    });
                    tree.expand({
                        id: "Item 12.5",
                        offset: 5,
                        children: 2,
                        parent: "Item 12"
                    });

                    scrollTo(10);
                    Utils.assertItems([
                        "Item 10",
                        "Item 11",
                        "Item 12",
                        "-Item 12.0",
                        "-Item 12.1",
                        "-Item 12.2",
                        "-Item 12.3",
                        "-Item 12.4",
                        "-Item 12.5",
                        "--Item 12.5.0",
                        "--Item 12.5.1"
                    ]);
                    scrollTo(11);
                    Utils.assertItems([
                        "Item 11",
                        "Item 12",
                        "-Item 12.0",
                        "-Item 12.1",
                        "-Item 12.2",
                        "-Item 12.3",
                        "-Item 12.4",
                        "-Item 12.5",
                        "--Item 12.5.0",
                        "--Item 12.5.1",
                        "-Item 12.6"
                    ]);

                    tree.collapse({
                        id: "Item 12",
                        children: 20,
                        offset: 12,
                        parent: null
                    });
                    Utils.assertItems([
                        "Item 11",
                        "Item 12",
                        "Item 13",
                        "Item 14",
                        "Item 15",
                        "Item 16",
                        "Item 17",
                        "Item 18",
                        "Item 19",
                        "Item 20",
                        "Item 21"
                    ]);
                    expect(collapseSpy.callCount).to.equal(2);
                    done();
                });
            });

            describe("scrollIntoView(Object item)", function() {
                it ("simple scroll - nothing expanded", function(done) {
                    createTree({});
                    tree.scrollIntoView({
                        id: "Item 30",
                        parent: null,
                        offset: 30,
                        children: 5
                    });

                    Utils.skipFrame(function() {
                        Utils.assertItems([
                            "Item 30",
                            "Item 31",
                            "Item 32",
                            "Item 33",
                            "Item 34",
                            "Item 35",
                            "Item 36",
                            "Item 37",
                            "Item 38",
                            "Item 39",
                            "Item 40"
                        ]);

                        done();
                    })
                });

                it ("single parent expanded above and below", function(done) {
                    createTree({});
                    Utils.toggleItem("Item 1");
                    tree.expand({
                        id: "Item 45",
                        parent: null,
                        offset: 45,
                        children: 5
                    });
                    Utils.skipFrame(function() {
                        tree.scrollIntoView({
                            id: "Item 30",
                            parent: null,
                            offset: 30,
                            children: 5
                        });

                        Utils.skipFrame(function() {
                            Utils.assertItems([
                                "Item 30",
                                "Item 31",
                                "Item 32",
                                "Item 33",
                                "Item 34",
                                "Item 35",
                                "Item 36",
                                "Item 37",
                                "Item 38",
                                "Item 39",
                                "Item 40"
                            ]);

                            done();
                        })
                    });

                });

                it ("multiple parents expanded above", function(done) {
                    createTree({});
                    Utils.toggleItem("Item 2");
                    Utils.toggleItem("Item 1");
                    Utils.skipFrame(function() {
                        tree.scrollIntoView({
                            id: "Item 30",
                            parent: null,
                            offset: 30,
                            children: 5
                        });

                        Utils.skipFrame(function() {
                            Utils.assertItems([
                                "Item 30",
                                "Item 31",
                                "Item 32",
                                "Item 33",
                                "Item 34",
                                "Item 35",
                                "Item 36",
                                "Item 37",
                                "Item 38",
                                "Item 39",
                                "Item 40"
                            ]);

                            done();
                        });

                    });
                });

                it ("should throw error if parent isn't expanded", function(done) {
                    createTree({});
                    expect(function() {
                        tree.scrollIntoView({
                            id: "Item 1.0",
                            parent: "Item 1",
                            children: 3,
                            offset: 0
                        });
                    }).to.throw(Error);
                    done();
                });

                it ("scroll to nested item", function(done) {
                    createTree({});
                    Utils.toggleItem("Item 1");
                    Utils.skipFrame(function() {
                        tree.scrollIntoView({
                            id: "Item 1.3",
                            parent: "Item 1",
                            children: 3,
                            offset: 3
                        });
                        Utils.skipFrame(function() {
                            Utils.assertItems([
                                "-Item 1.3",
                                "-Item 1.4",
                                "Item 2",
                                "Item 3",
                                "Item 4",
                                "Item 5",
                                "Item 6",
                                "Item 7",
                                "Item 8",
                                "Item 9",
                                "Item 10"
                            ]);

                            done();
                        })
                    });
                })

                it ("scroll to nested item, children expanded on same nested level", function(done) {
                    createTree({});
                    Utils.toggleItem("Item 1");
                    Utils.skipFrame(function() {
                        Utils.toggleItem("Item 1.0");
                        Utils.toggleItem("Item 1.4");
                        Utils.skipFrame(function() {
                            tree.scrollIntoView({
                                id: "Item 1.3",
                                parent: "Item 1",
                                children: 3,
                                offset: 3
                            });
                            Utils.skipFrame(function() {
                                Utils.assertItems([
                                    "-Item 1.3",
                                    "-Item 1.4",
                                    "--Item 1.4.0",
                                    "--Item 1.4.1",
                                    "--Item 1.4.2",
                                    "Item 2",
                                    "Item 3",
                                    "Item 4",
                                    "Item 5",
                                    "Item 6",
                                    "Item 7"
                                ]);

                                Utils.toggleItem("Item 1.3");
                                Utils.skipFrame(function() {
                                    tree.scrollIntoView({
                                        id: "Item 1.3.1",
                                        parent: "Item 1.3",
                                        offset: 1,
                                        children: 3
                                    });

                                    Utils.skipFrame(function() {
                                        Utils.assertItems([
                                            "--Item 1.3.1",
                                            "--Item 1.3.2",
                                            "-Item 1.4",
                                            "--Item 1.4.0",
                                            "--Item 1.4.1",
                                            "--Item 1.4.2",
                                            "Item 2",
                                            "Item 3",
                                            "Item 4",
                                            "Item 5"
                                        ]);
                                        done();
                                    });
                                })
                                
                            })
                        });
                    });
                });
            });
        });

    });

});
